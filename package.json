{
  "name": "career-pilot-root",
  "version": "1.0.0",
  "description": "Root workspace to launch CareerPilot backend and frontend concurrently",
  "scripts": {
    "dev:backend": "npm run dev --prefix Backend",
    "dev:frontend": "npm run dev --prefix Frontend",
    "dev": "concurrently --kill-others -n \"backend,frontend\" -c \"blue,green\" \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
